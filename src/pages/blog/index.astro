---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />

		<style>
			main {
				width: 860px;
			}

			.intro {
				margin-bottom: 1rem;
			}

			.intro h1 {
				margin-bottom: 0.35rem;
			}

			.category-tabs {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin: 1.5rem 0 1.75rem;
			}

			.category-tab {
				display: inline-flex;
				align-items: center;
				padding: 0.5rem 0.9rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				background: #fff;
				color: rgb(var(--gray-dark));
				font-size: 0.95rem;
				cursor: pointer;
			}

			.category-tab:hover {
				border-color: rgb(var(--gray));
			}

			.category-tab.active {
				background: #111827;
				color: #fff;
				border-color: #111827;
			}

			.current-category {
				margin: 0 0 1rem;
				color: rgb(var(--gray-dark));
				font-size: 0.95rem;
			}

			.post-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				gap: 0.85rem;
			}

			.post-item a {
				display: block;
				padding: 1rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				text-decoration: none;
			}

			.post-item a:hover {
				border-color: rgb(var(--gray));
			}

			.post-title {
				margin: 0;
				font-size: 1.15rem;
				line-height: 1.35;
			}

			.description {
				margin: 0.5rem 0;
				font-size: 0.95rem;
				color: rgb(var(--gray-dark));
			}

			.date {
				margin: 0;
				font-size: 0.9rem;
				color: rgb(var(--gray));
			}

			.empty-message {
				padding: 1.25rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				color: rgb(var(--gray-dark));
			}

			@media (max-width: 720px) {
				main {
					width: 100%;
				}

			.category-tabs {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				overflow-x: visible;
			}

			.category-tab {
				white-space: nowrap;
				flex: 0 0 auto;
				padding: 0.5rem 0.85rem;
			}
		}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<section class="intro">
				<h1>Blog</h1>
			
			</section>

			<nav class="category-tabs" aria-label="카테고리 필터">
				<button class="category-tab active" data-category="all">
					전체
				</button>

				<button class="category-tab" data-category="ai-tools">
					AI툴
				</button>

				<button class="category-tab" data-category="vibe-coding">
					바이브코딩
				</button>

				<button class="category-tab" data-category="automation">
					자동화
				</button>

				<button class="category-tab" data-category="gadgets">
					IT기기
				</button>

				<button class="category-tab" data-category="productivity">
					생산성
				</button>
			</nav>


			<section>
				<ul class="post-list">
					{
						posts.map((post) => (
							<li
								class="post-item"
								data-category={post.data.category || ''}
							>
								<a href={`/blog/${post.id}/`}>
									<h2 class="post-title">
										{post.data.title}
									</h2>

									<p class="description">
										{post.data.description}
									</p>

									<p class="date">
										<FormattedDate
											date={post.data.pubDate}
										/>
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>

		<Footer />

		<script>
			const tabs = document.querySelectorAll('.category-tab');
			const posts = document.querySelectorAll('.post-item');
			const currentCategoryText =
				document.querySelector('.current-category');

			const labels = {
				all: '전체',
				'ai-tools': 'AI툴',
				'vibe-coding': '바이브코딩',
				automation: '자동화',
				gadgets: 'IT기기',
				productivity: '생산성',
			};

			tabs.forEach((tab) => {
				tab.addEventListener('click', () => {
					const selected = tab.dataset.category;

					tabs.forEach((item) =>
						item.classList.remove('active'),
					);

					tab.classList.add('active');

					posts.forEach((post) => {
						const postCategory = post.dataset.category;

						if (
							selected === 'all' ||
							postCategory === selected
						) {
							post.style.display = 'block';
						} else {
							post.style.display = 'none';
						}
					});

					if (currentCategoryText) {
						currentCategoryText.textContent =
							`현재 카테고리: ${labels[selected]}`;
					}
				});
			});
		</script>
	</body>
</html>