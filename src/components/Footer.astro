---
const today = new Date();
---

<footer>
	<div class="container">
		<div class="links">
			<a href="/about">About</a>
			<a href="/contact">Contact</a>
			<a href="/privacy">Privacy</a>
		</div>
		<p class="copyright">&copy; {today.getFullYear()} 얼렁뚱땅 기획자의 IT 공부. All rights reserved.</p>
	</div>
</footer>
<style>
	footer {
		padding: 2rem 1rem;
		border-top: 1px solid rgb(var(--gray-light));
		background: #fff;
		color: rgb(var(--gray));
		text-align: center;
	}
	.container {
		width: 960px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
	}
	.links {
		display: flex;
		justify-content: center;
		flex-wrap: wrap;
		gap: 1rem;
		margin-bottom: 0.75rem;
	}
	.links a {
		text-decoration: none;
		color: rgb(var(--gray));
	}
	.links a:hover {
		color: rgb(var(--gray-dark));
	}
	.copyright {
		margin: 0;
		font-size: 0.95rem;
	}
</style>
