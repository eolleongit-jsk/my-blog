---
import { HEADER_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav class="container">
		<h2 class="logo">
			<a href="/">
				<img src="/logo.png" alt="블로그 로고" width="40" height="40" />
				<span>{HEADER_TITLE}</span>
			</a>
		</h2>
		<details class="menu">
			<summary aria-label="메뉴 열기">
				<span class="menu-icon" aria-hidden="true"></span>
			</summary>
			<div class="internal-links" aria-label="Primary">
				<HeaderLink href="/">Home</HeaderLink>
				<HeaderLink href="/blog">Blog</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
				<HeaderLink href="/contact">Contact</HeaderLink>
				<HeaderLink href="/privacy">Privacy</HeaderLink>
			</div>
		</details>
	</nav>
</header>
<style>
	header {
		margin: 0;
		background: white;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.container {
		width: 960px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.9rem 0;
	}
	.logo {
		flex: 1;
		text-align: left;
	}
	h2 {
		margin: 0;
		font-size: 1.5rem;
		line-height: 1;
	}
	.logo a,
	.logo a.active {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		text-decoration: none;
		color: rgb(var(--black));
	}
	.logo span {
		display: block;
		line-height: 1;
		font-weight: 500;
	}
	.logo img {
		width: 40px;
		height: 40px;
		border-radius: 999px;
		object-fit: cover;
		flex-shrink: 0;
	}
	.menu {
		position: relative;
		margin-left: auto;
		display: flex;
		align-items: center;
	}
	.menu summary {
		list-style: none;
		cursor: pointer;
		width: 40px;
		height: 40px;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		display: grid;
		place-items: center;
	}
	.menu summary::-webkit-details-marker {
		display: none;
	}
	.menu-icon,
	.menu-icon::before,
	.menu-icon::after {
		display: block;
		width: 18px;
		height: 2px;
		background: rgb(var(--gray-dark));
		border-radius: 999px;
		transition: transform 0.2s ease;
	}
	.menu-icon {
		position: relative;
	}
	.menu-icon::before,
	.menu-icon::after {
		content: '';
		position: absolute;
		left: 0;
	}
	.menu-icon::before {
		top: -6px;
	}
	.menu-icon::after {
		top: 6px;
	}
	.menu[open] .menu-icon {
		background: transparent;
	}
	.menu[open] .menu-icon::before {
		top: 0;
		transform: rotate(45deg);
	}
	.menu[open] .menu-icon::after {
		top: 0;
		transform: rotate(-45deg);
	}
	.internal-links {
		position: absolute;
		top: calc(100% + 0.5rem);
		right: 0;
		min-width: 180px;
		background: #fff;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 12px;
		padding: 0.4rem;
		box-shadow: 0 10px 30px rgba(var(--black), 0.08);
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		z-index: 20;
	}
	@media (max-width: 720px) {
		.container {
			max-width: calc(100% - 1.2em);
		}
		h2 {
			font-size: 1.34rem;
		}
	}
</style>
